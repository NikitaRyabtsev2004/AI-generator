{
  "name": "AI-generator",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "nodemon": "^3.1.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "react-tts": "^1.0.2",
    "recharts": "^3.8.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "node --max-old-space-size=8192 server/index.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:start\"",
    "client:start": "react-scripts start",
    "server:start": "node --max-old-space-size=8192 server/index.js",
    "server:dev": "nodemon server/index.js",
    "tools:reset-data": "node tools/reset-studio-data.js",
    "tools:reset-data:force": "node tools/reset-studio-data.js --yes",
    "tools:reset-data:dry": "node tools/reset-studio-data.js --yes --dry-run",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "proxy": "http://localhost:4000",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0"
  }
}
